rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Share tokens — anyone can read (unauthenticated portal access),
    // only authenticated users can create/update their own tokens.
    match /shareTokens/{token} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Shared portal: unauthenticated team members can read/write project data.
    // The portal token validates identity at the app layer.
    match /users/{userId}/project/data {
      allow read: if true;
      allow write: if true;
    }

    // Subscription doc — user can read their own only.
    // Cloud Functions use Admin SDK and bypass these rules (writes are server-only).
    match /users/{userId}/subscription/{doc} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Each user can only read and write their own project data.
    // No user can access another user's data.
    match /users/{userId}/project/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Team profiles — users can read/write their own profile only.
    match /teamProfiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
